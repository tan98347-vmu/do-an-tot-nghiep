SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,host.docker.internal,.ngrok-free.app
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,http://host.docker.internal,http://localhost:8080,http://127.0.0.1:8080,http://host.docker.internal:8000,http://host.docker.internal:8888,https://*.ngrok-free.app
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:8080

# PostgreSQL
DB_NAME=tennis_club_db
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_HOST=localhost
DB_PORT=5432

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_AI_MODEL=kimi-k2.6:cloud
# Model cloud rieng cho Prompt Preflight. Client nay khong co tool, RAG hay user context.
PROMPT_PREFLIGHT_MODEL=kimi-k2.6:cloud
PROMPT_PREFLIGHT_BASE_URL=http://localhost:11434
PROMPT_PREFLIGHT_ALLOWED_HOSTS=localhost,127.0.0.1,::1,host.docker.internal
PROMPT_PREFLIGHT_TIMEOUT_SECONDS=45
DEFAULT_EMBEDDING_MODEL=mxbai-embed-large
OCR_MODEL=qwen3-vl:4b
IMAGE_OCR_MODEL=qwen3-vl:235b-cloud

# === BEGIN R5: Backup encryption + signing ===
# Master key 32 bytes (256-bit) base64-encoded. Sinh bang:
#   python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
# Khong commit gia tri that. Khong log/print key.
BACKUP_ENCRYPTION_MASTER_KEY=
# True -> backend refuse start khi thieu key. False (mac dinh) -> chap nhan plaintext legacy.
BACKUP_ENCRYPTION_REQUIRED=False
# Path den RSA private/public key PEM de ky/verify backup. Bo trong -> skip ky.
# Sinh bang openssl:
#   openssl genrsa -out backup_signer.pem 2048
#   openssl rsa -in backup_signer.pem -pubout -out backup_signer.pub.pem
BACKUP_SIGNER_PRIVATE_KEY_PATH=
BACKUP_SIGNER_PUBLIC_KEY_PATH=
# === END R5 ===

# Manual edit / Collabora
MANUAL_EDIT_PROVIDER=collabora
# Local default: nginx on :8888 proxies Collabora so one public host can serve app + API + editor.
COLLABORA_PUBLIC_URL=http://127.0.0.1:8888
COLLABORA_EDITOR_PATH=/browser/dist/cool.html
# Recommended for CODE in Docker on the same Windows host.
MANUAL_EDIT_WOPI_SRC_BASE_URL=http://host.docker.internal:8888
MANUAL_EDIT_SESSION_TTL_SECONDS=3600
